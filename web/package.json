{
  "name": "euphrates-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm wasm && vite dev",
    "build": "pnpm wasm && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "wasm": "nix build ..#wasm && jco transpile result/lib/euph.wasm -o src/lib/wasm --instantiation"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.19.0",
    "@bytecodealliance/preview2-shim": "^0.17.9",
    "@molarmanful/fe-tools": "^0.4.3",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "core-js": "^3.49.0",
    "eslint": "^10.3.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-svelte": "^3.17.1",
    "fflate": "^0.8.2",
    "globals": "^17.6.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "typescript-svelte-plugin": "^0.3.52",
    "vite": "^8.0.10"
  },
  "packageManager": "pnpm@11.0.0-rc.0+sha512.1f08eadeea025e91448de6d5dee42a6c94764257000c043a9e36b8ff12849a72ebcb9c65fc1885094747249e52f53d8b73ada1181446bba81866810c8a4d3f6c"
}
